    "Captures volume up/down keys system-wide and adjusts the media player instead. Requires Accessibility permission." : {
      "comment" : "Description below the volume key intercept toggle",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erfasst die Lautstärketasten systemweit und steuert stattdessen den Media Player. Erfordert die Berechtigung für Bedienungshilfen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Captura las teclas de volumen en todo el sistema y ajusta el reproductor multimedia en su lugar. Requiere permiso de Accesibilidad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Capture les touches de volume à l'échelle du système et ajuste le lecteur multimédia à la place. Nécessite l'autorisation d'accessibilité."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fångar upp volymknappar i hela systemet och justerar mediaspelaren istället. Kräver tillgänglighetsbehörighet."
          }
        }
      }
    },
